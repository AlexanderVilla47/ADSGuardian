                                         "jsCode":  "const input = $json;\nconst allowedActions = new Set([\u0027alta\u0027, \u0027consulta\u0027, \u0027extension\u0027]);\nfunction isValidDateFormat(value) { if (typeof value !== \u0027string\u0027) return false; if (!/^\\d{4}-\\d{2}-\\d{2}$/.test(value)) return false; const [y,m,d]=value.split(\u0027-\u0027).map(Number); const dt = new Date(Date.UTC(y,m-1,d)); return dt.getUTCFullYear()===y \u0026\u0026 dt.getUTCMonth()===(m-1) \u0026\u0026 dt.getUTCDate()===d; }\nfunction fail(message, details = {}) { return [{ json: { ...input, action_original: input.action, action: \u0027validation_error\u0027, validation_error: { message, details } } }]; }\nif (!allowedActions.has(input.action)) return fail(\u0027`action` invalida. Usar: alta | consulta | extension\u0027, { action: input.action });\nif (input.action === \u0027alta\u0027) { const required=[\u0027Contrato_ID\u0027,\u0027Cliente\u0027,\u0027Regex_Anuncio\u0027,\u0027Fecha_Fin\u0027]; const missing=required.filter((f)=\u003e!String(input[f] ?? \u0027\u0027).trim()); if (missing.length) return fail(\u0027Faltan campos obligatorios para alta\u0027,{missing}); if (!isValidDateFormat(input.Fecha_Fin)) return fail(\u0027Fecha_Fin invalida. Formato requerido: YYYY-MM-DD\u0027); }\nif (input.action === \u0027extension\u0027) { const required=[\u0027Contrato_ID\u0027,\u0027Nueva_Fecha_Fin\u0027]; const missing=required.filter((f)=\u003e!String(input[f] ?? \u0027\u0027).trim()); if (missing.length) return fail(\u0027Faltan campos obligatorios para extension\u0027,{missing}); if (!isValidDateFormat(input.Nueva_Fecha_Fin)) return fail(\u0027Nueva_Fecha_Fin invalida. Formato requerido: YYYY-MM-DD\u0027); }\nif (input.action === \u0027consulta\u0027) { const dias=Number(input.dias_proximos ?? 7); if (!Number.isInteger(dias)||dias\u003c1||dias\u003e60) return fail(\u0027dias_proximos invalido. Debe ser entero entre 1 y 60\u0027); input.dias_proximos=dias; }\nreturn [{ json: input }];"
                                     }
