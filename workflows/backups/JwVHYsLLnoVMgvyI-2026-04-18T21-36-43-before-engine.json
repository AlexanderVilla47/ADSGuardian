    {
      "id": "precheck-build-response",
      "name": "Precheck - Build Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        60,
        -200
      ],
      "parameters": {
        "jsCode": "const adId = $('Precheck - Extract Ad ID').item.json.adId;\nconst rows = $input.all();\n\n// Test patterns\nif (adId.startsWith('AD-NON-ACTIVE-')) {\n  return [{ json: { statusCode: 200, body: { id: adId, name: 'Test Ad (Non-Active)',\n    status: 'PAUSED', effective_status: 'PAUSED' } } }];\n}\nif (adId.startsWith('AD-RETRY-')) {\n  return [{ json: { statusCode: 200, body: { id: adId, name: 'Test Ad (Retry)',\n    status: 'ACTIVE', effective_status: 'ACTIVE' } } }];\n}\n\n// GSheet lookup\nconst match = rows.find(r => r.json.ad_id === adId);\nif (!match) {\n  return [{ json: { statusCode: 200, body: { id: adId, name: 'Test Ad ' + adId,\n    status: 'ACTIVE', effective_status: 'ACTIVE' } } }];\n}\nconst row = match.json;\nreturn [{ json: { statusCode: 200, body: {\n  id: row.ad_id, name: row.ad_name, status: row.status, effective_status: row.status\n} } }];"
      }
    },
    {
      "id": "precheck-respond",
      "name": "Precheck - Respond",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        280,
        -200
      ],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ $json.body }}",
        "options": {
          "responseCode": "={{ $json.statusCode }}"
