    {
      "id": "pause-build-response",
      "name": "Pause - Build Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        280,
        100
      ],
      "parameters": {
        "jsCode": "const src = $('Pause - Extract Ad ID').item.json;\nconst adId = src.adId;\nconst rows = $input.all();\n\n// AD-RETRY-* returns 429 (rate limit)\nif (adId.startsWith('AD-RETRY-')) {\n  return [{ json: { statusCode: 429, body: { error: { message: 'Rate limit exceeded', code: 4 } } } }];\n}\n\n// Normal path: pause success\nreturn [{ json: { statusCode: 200, body: { success: true, id: adId } } }];"
      }
