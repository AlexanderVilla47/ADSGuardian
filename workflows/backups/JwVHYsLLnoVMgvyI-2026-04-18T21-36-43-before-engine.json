    {
      "id": "list-filter-respond",
      "name": "List - Filter by Pattern & Build Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -160,
        400
      ],
      "parameters": {
        "jsCode": "const pattern = String($('Mock List Ads Webhook').item.json.query?.pattern ?? '').trim();\nconst allRows = $input.all();\nlet filtered = allRows;\nif (pattern) {\n  try {\n    const regex = new RegExp(pattern, 'i');\n    filtered = allRows.filter(item => regex.test(item.json.ad_name ?? ''));\n  } catch (e) { filtered = []; }\n}\nconst data = filtered.map(item => ({ id: item.json.ad_id, name: item.json.ad_name, status: item.json.status, effective_status: item.json.status, campaign_name: item.json.campaign_name ?? '' }));\nreturn [{ json: { statusCode: 200, body: { data, paging: { cursors: { before: '', after: '' } } } } }];"
      }
    },
