                  {
                      "parameters":  {
                                         "jsCode":  "const query = $json.query ?? {};\nconst body = $json.body ?? {};\nconst params = $json.params ?? {};\nfunction pick(...values) {\n  for (const value of values) {\n    if (value !== undefined \u0026\u0026 value !== null \u0026\u0026 String(value).trim() !== \u0027\u0027) return value;\n  }\n  return undefined;\n}\nfunction asNumber(value) {\n  const n = Number(value);\n  return Number.isFinite(n) ? n : null;\n}\nconst adId = String(pick(params.adId, query.ad_id, body.ad_id, \u0027mock_ad_001\u0027)).trim();\nconst scenario = String(pick(query.scenario, body.scenario, \u0027success\u0027)).trim().toLowerCase();\nconst forcedStatus = asNumber(\n  pick(query.statusCode, query.status_code, body.statusCode, body.status_code)\n);\nlet statusCode = 200;\nif (forcedStatus !== null) statusCode = forcedStatus;\nelse if (scenario === \u0027retry429\u0027) statusCode = 429;\nelse if (scenario === \u0027retry500\u0027) statusCode = 500;\nelse if (scenario === \u0027fail400\u0027) statusCode = 400;\nlet effectiveStatus = String(\n  pick(query.effective_status, body.effective_status, \u0027ACTIVE\u0027)\n).trim().toUpperCase();\nif (scenario === \u0027inactive\u0027) effectiveStatus = \u0027PAUSED\u0027;\n// CLAVE: default name que matchea tu regex black\\\\s*friday\nlet name = String(\n  pick(query.name, body.name, \u0027Black Friday Teaser\u0027)\n).trim();\nif (scenario === \u0027name_mismatch\u0027) name = `UNMATCHED_${adId}`;\nconst successBody = {\n  id: adId,\n  name,\n  effective_status: effectiveStatus\n};\nconst errorBody = {\n  error: {\n    message: `Mock Meta precheck scenario=${scenario}`,\n    code: statusCode\n  },\n  ...successBody\n};\nreturn [{\n  json: {\n    statusCode,\n    body: statusCode \u003e= 200 \u0026\u0026 statusCode \u003c 300 ? successBody : errorBody,\n    scenario\n  }\n}];"
                                     },
