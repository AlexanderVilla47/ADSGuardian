    {
      "parameters": {
        "jsCode": "function normalize(row, fallback = {}) {\n  const normalized = { ...row };\n  normalized.Contrato_ID = String(normalized.Contrato_ID ?? fallback.Contrato_ID ?? '').trim();\n  normalized.Fecha_Fin = String(normalized.Fecha_Fin ?? fallback.Fecha_Fin ?? '').trim();\n\n  const regexCanon = String(normalized.Regex_Anuncio ?? normalized.regex_pattern ?? fallback.Regex_Anuncio ?? fallback.regex_pattern ?? '').trim();\n  normalized.Regex_Anuncio = regexCanon;\n  normalized.regex_pattern = String(normalized.regex_pattern ?? regexCanon).trim();\n\n  return normalized;\n}\n\nconst expanded = [];\nfor (const item of items) {\n  const source = item.json ?? {};\n  const vencidos = Array.isArray(source.vencidos) ? source.vencidos : [];\n\n  if (vencidos.length > 0) {\n    for (const row of vencidos) {\n      if (!row || typeof row !== 'object') continue;\n      expanded.push({ json: normalize(row, source) });\n    }\n    continue;\n  }\n\n  if (String(source.control_type || '').toLowerCase() === 'expired') {\n    expanded.push({ json: normalize(source, source) });\n  }\n}\n\nreturn expanded;"
