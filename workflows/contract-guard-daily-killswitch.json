    {
      "parameters": {
        "jsCode": "const response = $json;\nconst row = $item(0).$node['Init Retry Precheck'].json;\n\nconst attempt = Number(row.precheck_attempt || 1);\nconst maxAttempts = Number(row.precheck_max_attempts || 3);\nconst statusCode = Number(response.statusCode || 0);\nconst body = response.body || {};\n\nconst retryable = [429, 500].includes(statusCode);\nif (retryable && attempt < maxAttempts) {\n  return [{\n    json: {\n      ...row,\n      precheck_attempt: attempt + 1,\n      precheck_state: 'retry',\n      precheck_status_code: statusCode\n    }\n  }];\n}\n\nif (statusCode !== 200) {\n  return [{\n    json: {\n      ...row,\n      precheck_state: 'failed',\n      precheck_status_code: statusCode,\n      precheck_reason: 'meta_precheck_non_200'\n    }\n  }];\n}\n\nconst adNameMeta = String(body.name || '').trim();\nconst regexPattern = row.regex_pattern;\nlet regexMatchesMetaName = false;\ntry {\n  regexMatchesMetaName = !!regexPattern && new RegExp(regexPattern, 'i').test(adNameMeta);\n} catch (_) {\n  regexMatchesMetaName = false;\n}\n\nconst status = String(body.status || body.effective_status || '').toUpperCase();\nconst isActive = status === 'ACTIVE';\n\nif (!isActive || !regexMatchesMetaName) {\n  return [{\n    json: {\n      ...row,\n      precheck_state: 'not_actionable',\n      precheck_status_code: statusCode,\n      ad_status_meta: status || 'UNKNOWN',\n      regexMatchesMetaName,\n      ad_name_meta: adNameMeta\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    ...row,\n    precheck_state: 'ready_to_pause',\n    precheck_status_code: statusCode,\n    ad_status_meta: status,\n    regexMatchesMetaName,\n    ad_name_meta: adNameMeta\n  }\n}];"
      },
