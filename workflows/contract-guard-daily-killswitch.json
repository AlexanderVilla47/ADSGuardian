    {
      "parameters": {
        "jsCode": "const response = $json;\nconst row = $item(0).$node['Init Retry Pausa'].json;\n\nconst attempt = Number(row.pause_attempt || 1);\nconst maxAttempts = Number(row.pause_max_attempts || 3);\nconst statusCode = Number(response.statusCode || 0);\n\nconst isSuccess = statusCode >= 200 && statusCode < 300;\nif (isSuccess) {\n  return [{\n    json: {\n      ...row,\n      pause_state: 'success',\n      pause_status_code: statusCode\n    }\n  }];\n}\n\nconst retryable = [429, 500].includes(statusCode);\nif (retryable && attempt < maxAttempts) {\n  return [{\n    json: {\n      ...row,\n      pause_attempt: attempt + 1,\n      pause_state: 'retry',\n      pause_status_code: statusCode\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    ...row,\n    pause_state: 'failed',\n    pause_status_code: statusCode,\n    pause_reason: retryable ? 'retry_exhausted' : 'non_retryable_meta_response'\n  }\n}];"
